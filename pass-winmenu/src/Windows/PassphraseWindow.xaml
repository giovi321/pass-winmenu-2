<Window x:Class="PassWinmenu.Windows.PassphraseWindow"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Windows Hello setup" Height="180" Width="430" MinHeight="180" MinWidth="380"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize" KeyUp="Window_KeyUp">
	<Grid Margin="14">
		<StackPanel>
			<TextBlock x:Name="Prompt" TextWrapping="Wrap" Margin="0,0,0,12"
			           Text="Enter your GPG passphrase." />
			<Label Content="GPG passphrase:" Padding="0,0,0,2" />
			<PasswordBox x:Name="PassphraseBox" Height="24" Padding="3,3,3,3" FontFamily="Consolas" />
			<StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
				<Button x:Name="Btn_Cancel" Content="Cancel" Width="80" Click="Btn_Cancel_Click" />
				<Button x:Name="Btn_OK" Margin="10,0,0,0" Content="OK" IsDefault="True" Width="80" Click="Btn_OK_Click" />
			</StackPanel>
		</StackPanel>
	</Grid>
</Window>
